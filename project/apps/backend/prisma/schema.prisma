generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Club {
  id          String   @id @default(cuid())
  nombre      String
  slug        String   @unique
  logoUrl     String?
  activo      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admins    Admin[]
  jugadores Jugador[]
  canchas   Cancha[]
  reservas  Reserva[]

  @@map("clubs")
}

model Admin {
  id        String   @id @default(cuid())
  clubId    String
  nombre    String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@map("admins")
}

model Jugador {
  id        String   @id @default(cuid())
  clubId    String
  nombre    String
  apellido  String
  dni       String
  email     String?
  telefono  String?
  password  String
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club     Club      @relation(fields: [clubId], references: [id])
  reservas Reserva[]

  @@unique([clubId, dni])
  @@map("jugadores")
}

model Cancha {
  id      String  @id @default(cuid())
  clubId  String
  nombre  String
  tipo    String  @default("Cristal")
  indoor  Boolean @default(true)
  activo  Boolean @default(true)

  club     Club      @relation(fields: [clubId], references: [id])
  reservas Reserva[]

  @@map("canchas")
}

model Reserva {
  id          String   @id @default(cuid())
  clubId      String
  canchaId    String
  jugadorId   String?
  fecha       String
  horaInicio  String
  horaFin     String
  estado      String   @default("pendiente")
  precio      Float?
  esTurnoFijo Boolean  @default(false)
  tipo        String   @default("online")
  jugadores   String[]
  notas       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club    Club     @relation(fields: [clubId], references: [id])
  cancha  Cancha   @relation(fields: [canchaId], references: [id])
  jugador Jugador? @relation(fields: [jugadorId], references: [id])

  @@map("reservas")
}
