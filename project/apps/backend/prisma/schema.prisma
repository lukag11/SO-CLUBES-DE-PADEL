generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Club {
  id          String   @id @default(cuid())
  nombre      String
  slug        String   @unique
  logoUrl     String?
  activo      Boolean  @default(true)
  plan         String   @default("basico") // basico | pro | premium — define el feature gating
  estado       String   @default("prueba") // prueba | activo | suspendido
  trialHasta   DateTime?                    // fin del período de prueba (14 días). null = sin trial
  featuresExtra String[]                    // "regalitos": features extra fuera del plan
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admins         Admin[]
  jugadores      Jugador[]
  canchas        Cancha[]
  reservas       Reserva[]
  torneos        Torneo[]
  turnosFijos    TurnoFijo[]
  notificaciones Notificacion[]
  cargos         Cargo[]
  profesores     Profesor[]
  sponsors       Sponsor[]
  productos      Producto[]
  gastos         Gasto[]
  comandas       Comanda[]
  movimientosStock MovimientoStock[]
  categorias     Categoria[]

  @@map("clubs")
}

model Admin {
  id        String   @id @default(cuid())
  clubId    String
  nombre    String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@map("admins")
}

// Dueño de la PLATAFORMA (4to rol). Identidad separada, por encima de todos los
// clubes — NO pertenece a ningún club. Gestiona altas, planes y estado de tenants.
model PlatformAdmin {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_admins")
}

// Config global de la plataforma (clave-valor JSON). Guarda, entre otras cosas,
// la matriz de planes editable desde el panel (clave 'planMatriz').
model PlatformSetting {
  id        String   @id @default(cuid())
  clave     String   @unique
  valor     Json
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model Profesor {
  id           String   @id @default(cuid())
  clubId       String
  nombre       String
  apellido     String
  email        String
  password     String
  especialidad String?
  celular      String?
  canchasIds     String[]
  disponibilidad Json?
  activo         Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  club           Club           @relation(fields: [clubId], references: [id])
  reservas       Reserva[]
  notificaciones Notificacion[]

  @@unique([clubId, email])
  @@map("profesores")
}

model Jugador {
  id                  String   @id @default(cuid())
  clubId              String
  nombre              String
  apellido            String
  dni                 String
  email               String?
  telefono            String?
  password            String?
  cuentaActiva        Boolean  @default(true)
  activo              Boolean  @default(true)
  tokenVersion        Int      @default(0)
  // Perfil extendido
  genero              String?
  apodo               String?
  fechaNacimiento     String?
  provincia           String?
  ciudad              String?
  posicion            String?
  mano                String?
  categoria           String?
  frecuencia          String?
  diasDisponibles     String[]
  horariosDisponibles String[]
  perfilPublico       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  club           Club           @relation(fields: [clubId], references: [id])
  reservas       Reserva[]
  turnosFijos    TurnoFijo[]
  notificaciones Notificacion[]
  cargos         Cargo[]
  parejasComoJ1  Pareja[]       @relation("ParejaJugador1")
  parejasComoJ2  Pareja[]       @relation("ParejaJugador2")

  @@unique([clubId, dni])
  @@map("jugadores")
}

model Cancha {
  id           String  @id @default(cuid())
  clubId       String
  nombre       String
  tipo         String  @default("Cristal")
  indoor       Boolean @default(true)
  activo       Boolean @default(true)
  precioTurno  Int     @default(0)
  horarios     Json?

  club        Club        @relation(fields: [clubId], references: [id])
  reservas    Reserva[]
  turnosFijos TurnoFijo[]

  @@map("canchas")
}

model Reserva {
  id          String   @id @default(cuid())
  clubId      String
  canchaId    String
  jugadorId   String?
  profesorId  String?
  fecha       String
  horaInicio  String
  horaFin     String
  estado      String   @default("pendiente")
  precio      Int?
  pagado      Boolean  @default(false)
  metodoPago  String?  // efectivo | transferencia | mercadopago
  pagadoAt    DateTime?
  cobroOmitido Boolean @default(false) // turno impago que el club decide no cobrar (sale de cobranzas, no es ingreso)
  esTurnoFijo Boolean  @default(false)
  tipo        String   @default("online")
  jugadores   String[]
  notas       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club     Club      @relation(fields: [clubId], references: [id])
  cancha   Cancha    @relation(fields: [canchaId], references: [id])
  jugador  Jugador?  @relation(fields: [jugadorId], references: [id])
  profesor Profesor? @relation(fields: [profesorId], references: [id])

  @@map("reservas")
}

model TurnoFijo {
  id                  String   @id @default(cuid())
  clubId              String
  canchaId            String
  jugadorId           String?
  dia                 String   // 'lunes' | 'martes' | ... | 'domingo'
  horaInicio          String   // 'HH:MM'
  horaFin             String   // 'HH:MM'
  precio              Int?
  estado              String   @default("pendiente") // pendiente | confirmado | inactivo
  diasAusentes        String[] // fechas YYYY-MM-DD excluidas (cualquier ausencia)
  diasAusentesJugador String[] // fechas solicitadas por el jugador y confirmadas por admin
  ausenciasPendientes String[] // fechas pendientes de aprobación del admin
  desde               String   // YYYY-MM-DD — fecha desde la que rige el turno
  notas               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  club    Club     @relation(fields: [clubId], references: [id])
  cancha  Cancha   @relation(fields: [canchaId], references: [id])
  jugador Jugador? @relation(fields: [jugadorId], references: [id])

  @@map("turnos_fijos")
}

model Torneo {
  id                     String   @id @default(cuid())
  clubId                 String
  nombre                 String
  categorias             String[]
  formato                String   @default("Eliminación directa")
  genero                 String   @default("Masculino")
  estado                 String   @default("draft")
  cupoLibre              Boolean  @default(false)
  precioInscripcion      Int?     // precio de inscripción por jugador (mismo para todas las categorías)
  modoInscripcion        String   @default("abierta") // 'abierta' (deuda a j1+j2) | 'guardar_cupo' (deuda a j1 al inscribir, j2 al cargarse)
  cuposPorCategoria      Json     @default("{}")
  cupoEspera             Int      @default(5)
  cupoEsperaPorCategoria Json     @default("{}")
  generoPorCategoria     Json     @default("{}")
  canchasAsignadas       Int[]
  fechaInicio            String?
  fechaFin               String?
  fechaReprogramada      String?
  fechaLimiteInscripcion String?
  diaInicioEliminatoria  String?
  horaInicioEliminatoria String?
  fechaInicioEliminatoria String?
  fechaInicioQF           String?
  horaInicioQF            String?
  puntosPorVictoria      Int      @default(2)
  descripcion            String?
  grupos                 Json?
  brackets               Json?
  ganador                String?
  subcampeon             String?
  personalizacion        Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  club    Club     @relation(fields: [clubId], references: [id])
  parejas Pareja[]

  @@map("torneos")
}

model Cargo {
  id          String    @id @default(cuid())
  clubId      String
  jugadorId   String?   // null = venta a consumidor final / casual (sin ficha). Siempre pagado en ese caso.
  reservaId   String?
  comandaId   String?   // si el cargo pertenece a una comanda/mesa abierta (bar)
  parejaId    String?   // si el cargo viene de una inscripción a torneo (para limpiar al cancelar)
  concepto    String
  monto       Int
  estado      String    @default("pendiente") // pendiente | pagado | condonado
  tipo        String    @default("manual")    // cancelacion | manual | reserva | torneo | producto
  // Para reportes de bar/tienda (solo tipo 'producto'): snapshot de categoría/producto/costo al vender
  categoria   String?                          // categoría del producto al momento de la venta
  productoId  String?                          // referencia opcional al producto del catálogo
  costo       Int?                             // costo unitario × cantidad (para margen)
  cantidad    Int?                             // unidades vendidas (para descontar/reponer stock)
  vencimiento DateTime?                        // null = no vence; vencido = pendiente && vencimiento < hoy
  metodoPago  String?                          // efectivo | transferencia | mercadopago
  pagadoAt    DateTime?
  createdAt   DateTime  @default(now())

  club    Club     @relation(fields: [clubId], references: [id])
  jugador Jugador? @relation(fields: [jugadorId], references: [id], onDelete: Cascade)
  comanda Comanda? @relation(fields: [comandaId], references: [id], onDelete: SetNull)

  // Evita deudas duplicadas de inscripción (mismo jugador+pareja+tipo). Para tipo torneo
  // parejaId es non-null; los cargos manuales/cancelación tienen parejaId null (NULLs distintos en PG → no chocan).
  @@unique([parejaId, jugadorId, tipo])
  @@map("cargos")
}

// Comanda / mesa abierta del bar: acumula consumos (cargos) de un visitante sin ficha y se
// paga junta al cerrar. Mientras está abierta sus cargos son pendientes (no entran a caja).
model Comanda {
  id        String    @id @default(cuid())
  clubId    String
  etiqueta  String                          // libre: "Mesa 3", "Remera roja", "Cumple Juan"…
  estado    String    @default("abierta")    // abierta | cerrada
  createdAt DateTime  @default(now())
  closedAt  DateTime?

  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  cargos Cargo[]

  @@map("comandas")
}

// Categorías de productos del club (administrables: Bebidas, Comidas, Cafetería…).
model Categoria {
  id        String   @id @default(cuid())
  clubId    String
  nombre    String
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, nombre])
  @@map("categorias")
}

// Catálogo de productos vendibles del club (tubo de pelotas, grip, bebidas…). Solo lista de
// precios — sin control de stock en v1. Una venta genera un Cargo tipo 'producto'.
model Producto {
  id            String   @id @default(cuid())
  clubId        String
  nombre        String
  precio        Int
  costo         Int?     // costo de reposición (opcional) — para margen/rentabilidad
  categoria     String?  // Bebidas | Comidas | Golosinas | Insumos | Otros | (libre)
  activo        Boolean  @default(true)
  controlaStock Boolean  @default(false) // opt-in: solo se controla stock si está activo
  stock         Int      @default(0)     // unidades actuales (si controlaStock)
  stockMin      Int      @default(0)     // umbral de alerta de bajo stock
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  club        Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  movimientos MovimientoStock[]

  @@map("productos")
}

// Libro de movimientos de stock (trazabilidad): entrada (compra), salida (venta), ajuste.
model MovimientoStock {
  id         String   @id @default(cuid())
  clubId     String
  productoId String
  tipo       String   // entrada | salida | ajuste
  cantidad   Int      // +entra / -sale (firmado)
  costoUnit  Int?     // costo unitario al ingresar (compra)
  motivo     String?  // "Venta", "Compra factura #123", "Ajuste manual", "Anulación"…
  refTipo    String?  // gasto | cargo | comanda | manual
  refId      String?
  createdAt  DateTime @default(now())

  club     Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@map("movimientos_stock")
}

// Egreso / factura de proveedor (gasto del club). Diseñado "OCR-ready": los campos coinciden
// con lo que un lector de facturas por foto extraería, para que un asistente IA pre-llene el
// mismo formulario en el futuro (fuente: 'manual' hoy, 'ocr' después).
model Gasto {
  id            String    @id @default(cuid())
  clubId        String
  proveedor     String?
  concepto      String
  monto         Int
  categoria     String?
  fecha         String    // YYYY-MM-DD — fecha de la factura/gasto
  metodoPago    String?
  pagado        Boolean   @default(true)
  pagadoAt      DateTime?
  numeroFactura String?
  imagenUrl     String?
  fuente        String    @default("manual") // 'manual' | 'ocr'
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("gastos")
}

model Notificacion {
  id         String   @id @default(cuid())
  clubId     String
  jugadorId  String?  // null + profesorId null = para el admin del club
  profesorId String?  // non-null = para el profesor
  tipo       String
  leida      Boolean  @default(false)
  data       Json?
  createdAt  DateTime @default(now())

  club     Club      @relation(fields: [clubId], references: [id])
  jugador  Jugador?  @relation(fields: [jugadorId], references: [id], onDelete: Cascade)
  profesor Profesor? @relation(fields: [profesorId], references: [id], onDelete: Cascade)

  @@map("notificaciones")
}

model Sponsor {
  id        String   @id @default(cuid())
  clubId    String
  nombre    String
  logoUrl   String
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("sponsors")
}

model Pareja {
  id               String   @id @default(cuid())
  torneoId         String
  clubId           String
  jugador1         String
  jugador2         String
  jugador1Dni      String?
  jugador2Dni      String?
  jugador1Id       String?  // FK opcional → Jugador (auto-linked por DNI)
  jugador2Id       String?  // FK opcional → Jugador (auto-linked por DNI)
  sinCompanero     Boolean  @default(false)
  estado           String   @default("inscripto")  // inscripto | espera
  categoria        String
  fecha            String?
  disponibilidad   Json?
  prefiereMismoDia Boolean  @default(false)
  createdAt        DateTime @default(now())

  torneo    Torneo   @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  jugador1R Jugador? @relation("ParejaJugador1", fields: [jugador1Id], references: [id], onDelete: SetNull)
  jugador2R Jugador? @relation("ParejaJugador2", fields: [jugador2Id], references: [id], onDelete: SetNull)

  @@map("parejas")
}
