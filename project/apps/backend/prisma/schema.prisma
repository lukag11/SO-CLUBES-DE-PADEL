generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Club {
  id          String   @id @default(cuid())
  nombre      String
  slug        String   @unique
  logoUrl     String?
  activo      Boolean  @default(true)
  plan         String   @default("basico") // basico | pro | premium — define el feature gating
  estado       String   @default("prueba") // prueba | activo | suspendido
  trialHasta   DateTime?                    // fin del período de prueba (14 días). null = sin trial
  featuresExtra String[]                    // "regalitos": features extra fuera del plan
  config      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admins         Admin[]
  jugadores      Jugador[]
  canchas        Cancha[]
  reservas       Reserva[]
  torneos        Torneo[]
  turnosFijos    TurnoFijo[]
  notificaciones Notificacion[]
  cargos         Cargo[]
  profesores     Profesor[]
  sponsors       Sponsor[]
  productos      Producto[]
  gastos         Gasto[]
  comandas       Comanda[]
  movimientosStock MovimientoStock[]
  categorias     Categoria[]
  convocatorias  Convocatoria[]
  solicitudesJugador SolicitudJugador[]
  eventosUso     EventoUso[]
  costos         Costo[]
  arqueosCaja    ArqueoCaja[]
  pagos          Pago[]
  mpConexion     MpConexion?   // conexión OAuth de Mercado Pago (NUNCA incluir en lecturas del club)

  @@map("clubs")
}

// Conexión OAuth de Mercado Pago de un club (el club conectó SU cuenta). Los tokens van
// CIFRADOS (AES-256-GCM, lib/cripto.js) — NUNCA en Club.config (que se serializa al front).
// Nunca incluir en `include` de lecturas del club ni loguear los tokens. Ver diseño en
// memoria project_mp_oauth_diseno.
model MpConexion {
  id                 String    @id @default(cuid())
  clubId             String    @unique                 // 1-1 con Club
  club               Club      @relation(fields: [clubId], references: [id], onDelete: Cascade)
  mpUserId           String    @unique                 // user_id de MP (una cuenta MP no en dos clubes)
  accessTokenEnc     String                            // AES-256-GCM (iv:tag:ct)
  refreshTokenEnc    String                            // AES-256-GCM
  scope              String?
  expiresAt          DateTime                          // vencimiento del access_token
  keyVersion         Int       @default(1)             // rotación de la enc key
  estado             String    @default("conectado")   // conectado | desconectado
  desconectadoMotivo String?                           // refresh_failed | revocado | error
  conectadoAt        DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@map("mp_conexiones")
}

// Estado anti-CSRF del flujo OAuth: aleatorio, single-use, TTL corto. El clubId sale de
// acá (server-side), NUNCA de un query param del callback (anti confused-deputy).
model MpOAuthState {
  id        String    @id @default(cuid())
  state     String    @unique                          // random 32B base64url
  clubId    String
  usedAt    DateTime?                                  // single-use: se marca antes de canjear el code
  expiresAt DateTime                                   // now + 10 min
  createdAt DateTime  @default(now())

  @@index([expiresAt])
  @@map("mp_oauth_states")
}

model Admin {
  id        String   @id @default(cuid())
  clubId    String
  nombre    String
  email     String   @unique
  password  String
  rol       String   @default("owner") // owner (dueño, acceso total) | staff (empleado con permisos)
  permisos  String[]                    // módulos habilitados para staff (owner ignora esto)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  club Club @relation(fields: [clubId], references: [id])

  @@map("admins")
}

// Dueño de la PLATAFORMA (4to rol). Identidad separada, por encima de todos los
// clubes — NO pertenece a ningún club. Gestiona altas, planes y estado de tenants.
model PlatformAdmin {
  id        String   @id @default(cuid())
  nombre    String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("platform_admins")
}

// Config global de la plataforma (clave-valor JSON). Guarda, entre otras cosas,
// la matriz de planes editable desde el panel (clave 'planMatriz').
model PlatformSetting {
  id        String   @id @default(cuid())
  clave     String   @unique
  valor     Json
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

model Profesor {
  id           String   @id @default(cuid())
  clubId       String
  nombre       String
  apellido     String
  email        String
  password     String
  especialidad String?
  celular      String?
  canchasIds     String[]
  disponibilidad Json?
  activo         Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  club           Club           @relation(fields: [clubId], references: [id])
  reservas       Reserva[]
  notificaciones Notificacion[]

  @@unique([clubId, email])
  @@map("profesores")
}

model Jugador {
  id                  String   @id @default(cuid())
  clubId              String
  nombre              String
  apellido            String
  dni                 String
  email               String?
  telefono            String?
  password            String?
  cuentaActiva        Boolean  @default(true)
  activo              Boolean  @default(true)
  tokenVersion        Int      @default(0)
  // Perfil extendido
  genero              String?
  apodo               String?
  fechaNacimiento     String?
  provincia           String?
  ciudad              String?
  posicion            String?
  mano                String?
  categoria           String?
  frecuencia          String?
  diasDisponibles     String[]
  horariosDisponibles String[]
  perfilPublico       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  club           Club           @relation(fields: [clubId], references: [id])
  reservas       Reserva[]
  turnosFijos    TurnoFijo[]
  notificaciones Notificacion[]
  cargos         Cargo[]
  parejasComoJ1  Pareja[]       @relation("ParejaJugador1")
  parejasComoJ2  Pareja[]       @relation("ParejaJugador2")
  resetTokens    PasswordResetToken[]
  convocatoriaCupos ConvocatoriaCupo[]
  solicitudesHechas    SolicitudJugador[] @relation("SolicitudSolicitante")
  solicitudesCubiertas SolicitudJugador[] @relation("SolicitudCubierto")
  participacionesPartido SolicitudParticipante[]
  cambiosCategoria       CambioCategoria[]
  pagos                  Pago[]

  @@unique([clubId, dni])
  @@map("jugadores")
}

// Auditoría de ascensos/descensos de categoría. Se graba en CADA cambio (WIarky o admin
// manual) para tener trazabilidad: de qué categoría a cuál, por qué y quién lo hizo.
// Ascenso = logro (regla del dominio); descenso = manual, correctivo.
model CambioCategoria {
  id        String   @id @default(cuid())
  clubId    String
  jugadorId String
  de        String?  // categoría anterior (null si no tenía)
  a         String   // categoría nueva
  tipo      String   // 'ascenso' | 'descenso'
  origen    String   // 'wiark' | 'admin_manual'
  motivo    String?  // por qué (criollo, para auditoría)
  adminId   String?  // admin que lo hizo (null = automático/WIarky)
  createdAt DateTime @default(now())

  jugador Jugador @relation(fields: [jugadorId], references: [id], onDelete: Cascade)

  @@index([clubId, jugadorId])
  @@map("cambios_categoria")
}

// Token de un solo uso para recuperar contraseña del jugador (por DNI + email).
// Hoy se entrega en la respuesta; al deployar se manda por email (mismo flujo).
model PasswordResetToken {
  id        String    @id @default(cuid())
  jugadorId String
  tokenHash String    @unique // sha256 del token crudo (el crudo nunca se guarda)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  jugador Jugador @relation(fields: [jugadorId], references: [id], onDelete: Cascade)

  @@index([jugadorId])
  @@map("password_reset_tokens")
}

model Cancha {
  id           String  @id @default(cuid())
  clubId       String
  nombre       String
  tipo         String  @default("Cristal")
  indoor       Boolean @default(true)
  activo       Boolean @default(true)
  precioTurno  Int     @default(0)
  horarios     Json?

  club        Club        @relation(fields: [clubId], references: [id])
  reservas    Reserva[]
  turnosFijos TurnoFijo[]

  @@map("canchas")
}

model Reserva {
  id          String   @id @default(cuid())
  clubId      String
  canchaId    String
  jugadorId   String?
  profesorId  String?
  fecha       String
  horaInicio  String
  horaFin     String
  estado      String   @default("pendiente")
  precio      Int?
  tarifaLista Int?     // snapshot del precio de lista de la cancha al crear la reserva (para yield real; la tarifa cambia con inflación)
  pagado      Boolean  @default(false)
  saldoPagado Int      @default(0)  // plata ya imputada (pago parcial). pagado deriva: saldoPagado >= precio
  metodoPago  String?  // efectivo | transferencia | mercadopago (legacy: método del pago completo simple)
  pagadoAt    DateTime?
  cobroOmitido Boolean @default(false) // turno impago que el club decide no cobrar (sale de cobranzas, no es ingreso)
  esTurnoFijo Boolean  @default(false)
  tipo        String   @default("online")
  jugadores   String[]
  cobroRoster String[] @default([]) // jugadorIds del cobro en curso (armado del split) — recordar al reabrir sin crear cargos
  notas       String?
  convocatoriaId String?  // si la reserva es una de las canchas de una convocatoria (evento)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  club     Club      @relation(fields: [clubId], references: [id])
  cancha   Cancha    @relation(fields: [canchaId], references: [id])
  jugador  Jugador?  @relation(fields: [jugadorId], references: [id])
  profesor Profesor? @relation(fields: [profesorId], references: [id])
  convocatoria Convocatoria? @relation(fields: [convocatoriaId], references: [id], onDelete: SetNull)

  @@map("reservas")
}

model TurnoFijo {
  id                  String   @id @default(cuid())
  clubId              String
  canchaId            String
  jugadorId           String?
  dia                 String   // 'lunes' | 'martes' | ... | 'domingo'
  horaInicio          String   // 'HH:MM'
  horaFin             String   // 'HH:MM'
  precio              Int?
  estado              String   @default("pendiente") // pendiente | confirmado | inactivo
  diasAusentes        String[] // fechas YYYY-MM-DD excluidas (cualquier ausencia)
  diasAusentesJugador String[] // fechas solicitadas por el jugador y confirmadas por admin
  ausenciasPendientes String[] // fechas pendientes de aprobación del admin
  desde               String   // YYYY-MM-DD — fecha desde la que rige el turno
  notas               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  club    Club     @relation(fields: [clubId], references: [id])
  cancha  Cancha   @relation(fields: [canchaId], references: [id])
  jugador Jugador? @relation(fields: [jugadorId], references: [id])

  @@map("turnos_fijos")
}

model Torneo {
  id                     String   @id @default(cuid())
  clubId                 String
  nombre                 String
  categorias             String[]
  formato                String   @default("Eliminación directa")
  genero                 String   @default("Masculino")
  estado                 String   @default("draft")
  cupoLibre              Boolean  @default(false)
  precioInscripcion      Int?     // precio de inscripción por jugador (mismo para todas las categorías)
  modoInscripcion        String   @default("abierta") // 'abierta' (deuda a j1+j2) | 'guardar_cupo' (deuda a j1 al inscribir, j2 al cargarse)
  cuposPorCategoria      Json     @default("{}")
  cupoEspera             Int      @default(5)
  cupoEsperaPorCategoria Json     @default("{}")
  generoPorCategoria     Json     @default("{}")
  canchasAsignadas       Int[]
  fechaInicio            String?
  fechaFin               String?
  fechaReprogramada      String?
  fechaLimiteInscripcion String?
  diaInicioEliminatoria  String?
  horaInicioEliminatoria String?
  fechaInicioEliminatoria String?
  fechaInicioQF           String?
  horaInicioQF            String?
  puntosPorVictoria      Int      @default(2)
  descripcion            String?
  grupos                 Json?
  brackets               Json?
  ganador                String?
  subcampeon             String?
  personalizacion        Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  club    Club     @relation(fields: [clubId], references: [id])
  parejas Pareja[]

  @@map("torneos")
}

model Cargo {
  id          String    @id @default(cuid())
  clubId      String
  jugadorId   String?   // null = venta a consumidor final / casual (sin ficha). Siempre pagado en ese caso.
  reservaId   String?
  comandaId   String?   // si el cargo pertenece a una comanda/mesa abierta (bar)
  parejaId    String?   // si el cargo viene de una inscripción a torneo (para limpiar al cancelar)
  concepto    String
  monto       Int
  saldoPagado Int       @default(0)  // plata ya imputada (pago parcial). estado 'pagado' deriva: saldoPagado >= monto
  estado      String    @default("pendiente") // pendiente | pagado | condonado
  tipo        String    @default("manual")    // cancelacion | manual | reserva | torneo | producto
  // Para reportes de bar/tienda (solo tipo 'producto'): snapshot de categoría/producto/costo al vender
  categoria   String?                          // categoría del producto al momento de la venta
  productoId  String?                          // referencia opcional al producto del catálogo
  costo       Int?                             // costo unitario × cantidad (para margen)
  cantidad    Int?                             // unidades vendidas (para descontar/reponer stock)
  vencimiento DateTime?                        // null = no vence; vencido = pendiente && vencimiento < hoy
  metodoPago  String?                          // efectivo | transferencia | mercadopago
  pagadoAt    DateTime?
  createdAt   DateTime  @default(now())

  club    Club     @relation(fields: [clubId], references: [id])
  jugador Jugador? @relation(fields: [jugadorId], references: [id], onDelete: Cascade)
  comanda Comanda? @relation(fields: [comandaId], references: [id], onDelete: SetNull)

  // Evita deudas duplicadas de inscripción (mismo jugador+pareja+tipo). Para tipo torneo
  // parejaId es non-null; los cargos manuales/cancelación tienen parejaId null (NULLs distintos en PG → no chocan).
  @@unique([parejaId, jugadorId, tipo])
  @@map("cargos")
}

// Comanda / mesa abierta del bar: acumula consumos (cargos) de un visitante sin ficha y se
// paga junta al cerrar. Mientras está abierta sus cargos son pendientes (no entran a caja).
model Comanda {
  id        String    @id @default(cuid())
  clubId    String
  etiqueta  String                          // libre: "Mesa 3", "Remera roja", "Cumple Juan"…
  estado    String    @default("abierta")    // abierta | cerrada
  createdAt DateTime  @default(now())
  closedAt  DateTime?

  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  cargos Cargo[]

  @@map("comandas")
}

// Categorías de productos del club (administrables: Bebidas, Comidas, Cafetería…).
model Categoria {
  id        String   @id @default(cuid())
  clubId    String
  nombre    String
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([clubId, nombre])
  @@map("categorias")
}

// Catálogo de productos vendibles del club (tubo de pelotas, grip, bebidas…). Solo lista de
// precios — sin control de stock en v1. Una venta genera un Cargo tipo 'producto'.
model Producto {
  id            String   @id @default(cuid())
  clubId        String
  nombre        String
  precio        Int
  costo         Int?     // costo de reposición (opcional) — para margen/rentabilidad
  categoria     String?  // Bebidas | Comidas | Golosinas | Insumos | Otros | (libre)
  activo        Boolean  @default(true)
  controlaStock Boolean  @default(false) // opt-in: solo se controla stock si está activo
  stock         Int      @default(0)     // unidades actuales (si controlaStock)
  stockMin      Int      @default(0)     // umbral de alerta de bajo stock
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  club        Club              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  movimientos MovimientoStock[]

  @@map("productos")
}

// Libro de movimientos de stock (trazabilidad): entrada (compra), salida (venta), ajuste.
model MovimientoStock {
  id         String   @id @default(cuid())
  clubId     String
  productoId String
  tipo       String   // entrada | salida | ajuste
  cantidad   Int      // +entra / -sale (firmado)
  costoUnit  Int?     // costo unitario al ingresar (compra)
  motivo     String?  // "Venta", "Compra factura #123", "Ajuste manual", "Anulación"…
  refTipo    String?  // gasto | cargo | comanda | manual
  refId      String?
  createdAt  DateTime @default(now())

  club     Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)

  @@map("movimientos_stock")
}

// Egreso / factura de proveedor (gasto del club). Diseñado "OCR-ready": los campos coinciden
// con lo que un lector de facturas por foto extraería, para que un asistente IA pre-llene el
// mismo formulario en el futuro (fuente: 'manual' hoy, 'ocr' después).
model Gasto {
  id            String    @id @default(cuid())
  clubId        String
  proveedor     String?
  cuitProveedor String?   // CUIT del proveedor (lo lee el OCR; útil para el contador)
  tipoComprobante String? // Factura A|B|C, Ticket, Remito, etc. (lo lee el OCR)
  concepto      String
  monto         Int
  categoria     String?
  fecha         String    // YYYY-MM-DD — fecha de emisión de la factura/gasto
  vencimiento   String?   // YYYY-MM-DD — fecha de vencimiento DE PAGO (solo facturas a crédito)
  metodoPago    String?
  pagado        Boolean   @default(true)
  pagadoAt      DateTime?
  numeroFactura String?
  imagenUrl     String?
  fuente        String    @default("manual") // 'manual' | 'ocr'
  costoId       String?   // vínculo: este gasto es el PAGO de un Costo estructural (puente Costo↔Gasto)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  club  Club   @relation(fields: [clubId], references: [id], onDelete: Cascade)
  costo Costo? @relation(fields: [costoId], references: [id], onDelete: SetNull)

  @@index([clubId, costoId])
  @@map("gastos")
}

// Costo estructural del club (la "mochila" fija + los variables) que el DUEÑO carga a mano —
// no lo genera la operación. Es el cimiento de break-even, contribución por sector y flujo 90d.
// Diseño simple a propósito (sin drivers de asignación): costo directo por sector cuando se
// sabe, y el resto (sector null = "general") se prorratea por ingreso al calcular márgenes.
model Costo {
  id           String   @id @default(cuid())
  clubId       String
  concepto     String                          // "Alquiler", "Sueldo Juan", "Luz"
  categoria    String                          // alquiler | sueldos | energia | amortizacion | otros
  tipo         String   @default("fijo")       // fijo | variable
  monto        Int                             // monto por período (según periodicidad)
  periodicidad String   @default("mensual")    // mensual | bimestral | anual | unico
  diaPago      Int?                            // día del mes que vence (para el flujo 90d)
  mesesPago    Int[]                           // p/anual: [6,12] aguinaldo · vacío = todos
  sector       String?                         // bar | clases | canchas | proshop | null(general→prorratea)
  ajustaPorIPC Boolean  @default(false)        // para la capa Argentina (real vs nominal)
  moneda       String   @default("ARS")        // ARS | USD (costos dolarizados)
  activo       Boolean  @default(true)
  desde        String?                         // YYYY-MM-DD vigencia (la tarifa cambia con inflación)
  hasta        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  club   Club    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  gastos Gasto[] // pagos reales de este costo (puente Costo↔Gasto)

  @@index([clubId, activo])
  @@map("costos")
}

// ARQUEO DE CAJA (control del efectivo físico). Una sesión = un turno de un empleado.
// Al abrir declara el fondo (cambio). Al cerrar cuenta la plata y el sistema compara con
// lo ESPERADO (fondo + cobros en efectivo del turno − egresos en efectivo). SOLO EFECTIVO:
// transferencias/MP no van al cajón, se concilian aparte. Los totales se CONGELAN al cerrar
// (documento histórico inmutable: si mañana se edita un cobro viejo, el arqueo no cambia).
model ArqueoCaja {
  id                String    @id @default(cuid())
  clubId            String
  empleadoId        String    // Admin que abrió la caja
  empleadoNombre    String?   // snapshot (para el historial aunque cambie/borre el admin)
  estado            String    @default("abierta") // abierta | cerrada
  abiertoAt         DateTime  @default(now())
  cerradoAt         DateTime?
  fondoInicial      Int       @default(0)         // "cambio" de arranque (no es ganancia)
  cobrosEfectivo    Int?      // snapshot al cerrar: cobrado en efectivo durante la sesión
  egresosEfectivo   Int?      // snapshot al cerrar: retiros/egresos en efectivo (movimientos)
  efectivoEsperado  Int?      // fondo + cobros − egresos (congelado al cerrar)
  efectivoDeclarado Int?      // lo que el empleado contó del cajón
  diferencia        Int?      // declarado − esperado (negativo = faltante)
  notas             String?   // motivo si hay diferencia
  cerradoPorNombre  String?   // quién cerró (puede diferir de quién abrió)
  createdAt         DateTime  @default(now())

  club        Club             @relation(fields: [clubId], references: [id], onDelete: Cascade)
  movimientos MovimientoCaja[]

  @@index([clubId, estado])
  @@map("arqueos_caja")
}

// Egresos/ingresos de EFECTIVO del cajón durante una sesión (no son cobros de ventas):
// retiro del dueño, compra de hielo, vuelto extra. Ajustan el efectivo esperado del arqueo.
model MovimientoCaja {
  id        String   @id @default(cuid())
  arqueoId  String
  tipo      String   // egreso | ingreso
  monto     Int
  concepto  String
  createdAt DateTime @default(now())

  arqueo ArqueoCaja @relation(fields: [arqueoId], references: [id], onDelete: Cascade)

  @@index([arqueoId])
  @@map("movimientos_caja")
}

// ──────────────────────────────────────────────────────────────────────────────
// PAGO — "libro de plata" separado de la deuda (ítems Reserva/Cargo). Un Pago es un
// evento de cobro: puede ser PARCIAL (paga parte de la deuda del jugador, FIFO al más
// viejo) y con SPLIT de métodos (varias líneas: ej. efectivo + transferencia). La caja
// (arqueo + reporte por método) lee de PagoLinea, así el efectivo del cajón es EXACTO
// aunque el cobro haya sido mixto (antes se elegía 1 método y la caja mentía).
// `imputaciones` guarda a qué ítems y por cuánto se aplicó, para revertir al anular.
// ──────────────────────────────────────────────────────────────────────────────
model Pago {
  id           String    @id @default(cuid())
  clubId       String
  jugadorId    String?   // null = mostrador (siempre total, no parcial)
  total        Int       // suma de líneas = suma imputado a los ítems
  imputaciones Json      // [{ origen:'reserva'|'cargo', refId, monto }] — para revertir saldoPagado al anular
  anuladoAt    DateTime? // anulado = revertido (no cuenta en caja); no se borra (auditoría)
  pagadoAt     DateTime  @default(now())
  createdAt    DateTime  @default(now())

  club    Club        @relation(fields: [clubId], references: [id], onDelete: Cascade)
  jugador Jugador?    @relation(fields: [jugadorId], references: [id], onDelete: SetNull)
  lineas  PagoLinea[]

  @@index([clubId, pagadoAt])
  @@map("pagos")
}

// Una línea de método dentro de un Pago (el split). La caja suma estas líneas por método.
model PagoLinea {
  id     String @id @default(cuid())
  pagoId String
  metodo String // efectivo | transferencia | mercadopago
  monto  Int

  pago Pago @relation(fields: [pagoId], references: [id], onDelete: Cascade)

  @@index([pagoId])
  @@map("pago_lineas")
}

// Intento de cobro con Mercado Pago (Checkout Pro). FUENTE DE VERDAD del pago online:
// da idempotencia (mpPaymentId @unique) y trazabilidad (iniciado → pending → approved/refunded).
// La acreditación REAL (crear Pago + imputar FIFO) ocurre UNA sola vez en la transición → approved,
// verificada por webhook + re-consulta GET /v1/payments/{id}. NUNCA acreditar por el back_url.
// clubId/refId/pagoId son referencias simples (sin FK Prisma) para no tocar Club/Pago. Ver RN-70..77
// y la memoria project_mercadopago_fase2.
model PagoMP {
  id            String    @id @default(cuid())
  clubId        String                                  // club que cobra (token MP resuelto aparte)
  origen        String                                  // 'cargo' | 'reserva' — qué se está cobrando
  refId         String                                  // id del Cargo (o Reserva) que se cobra
  montoEsperado Int                                     // restante de la deuda al generar el link (pesos)
  preferenceId  String?                                 // id de la preferencia de Checkout Pro
  initPoint     String?                                 // URL de pago (init_point) para mandar por WhatsApp
  mpPaymentId   String?   @unique                       // id del payment de MP → idempotencia (llega en el webhook)
  status        String    @default("iniciado")          // iniciado | pending | approved | rejected | refunded | charged_back | cancelled
  statusDetail  String?                                 // status_detail crudo de MP (auditoría)
  pagoId        String?                                 // ref al Pago creado al acreditar (una sola vez)
  expiraAt      DateTime?                               // vencimiento del link (RN-76)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clubId, refId])
  @@map("pagos_mp")
}

model Notificacion {
  id         String   @id @default(cuid())
  clubId     String
  jugadorId  String?  // null + profesorId null = para el admin del club
  profesorId String?  // non-null = para el profesor
  tipo       String
  leida      Boolean  @default(false)
  data       Json?
  createdAt  DateTime @default(now())

  club     Club      @relation(fields: [clubId], references: [id])
  jugador  Jugador?  @relation(fields: [jugadorId], references: [id], onDelete: Cascade)
  profesor Profesor? @relation(fields: [profesorId], references: [id], onDelete: Cascade)

  @@map("notificaciones")
}

// Telemetría de uso (para el agente de onboarding / mejora continua): registra qué hace el
// admin/dueño en la plataforma para detectar dónde se traba, qué no usa y dónde abandona.
// SIN PII sensible: solo tipo de evento + referencia de pantalla/acción. "Caño bajo el piso":
// hay que capturarlo desde el día 1 porque el onboarding del primer club real no se repite.
model EventoUso {
  id        String   @id @default(cuid())
  clubId    String
  adminId   String?  // quién (opcional) — admin/staff que generó el evento
  tipo      String   // pantalla | click | abandono | error | ayuda_abierta
  ref       String   // "dashboard" | "costos.nuevo" | "checkout.split" | ...
  meta      Json?    // contexto extra (sin datos sensibles)
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@index([clubId, tipo, createdAt])
  @@map("eventos_uso")
}

model Sponsor {
  id        String   @id @default(cuid())
  clubId    String
  nombre    String
  logoUrl   String
  createdAt DateTime @default(now())

  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@map("sponsors")
}

model Pareja {
  id               String   @id @default(cuid())
  torneoId         String
  clubId           String
  jugador1         String
  jugador2         String
  jugador1Dni      String?
  jugador2Dni      String?
  jugador1Id       String?  // FK opcional → Jugador (auto-linked por DNI)
  jugador2Id       String?  // FK opcional → Jugador (auto-linked por DNI)
  sinCompanero     Boolean  @default(false)
  estado           String   @default("inscripto")  // inscripto | espera
  categoria        String
  fecha            String?
  disponibilidad   Json?
  prefiereMismoDia Boolean  @default(false)
  observacionCategoria String? // "cut" manual del admin: motivo por el que está observada (pasada de categoría)
  createdAt        DateTime @default(now())

  torneo    Torneo   @relation(fields: [torneoId], references: [id], onDelete: Cascade)
  jugador1R Jugador? @relation("ParejaJugador1", fields: [jugador1Id], references: [id], onDelete: SetNull)
  jugador2R Jugador? @relation("ParejaJugador2", fields: [jugador2Id], references: [id], onDelete: SetNull)

  @@map("parejas")
}

// Convocatoria a un Americano / Super 8: el admin la abre, los jugadores se suman ("Voy").
// Al llenarse → genera fixture (lib/eventos.js) + reserva canchas. Loop social del club.
model Convocatoria {
  id              String   @id @default(cuid())
  clubId          String
  modalidad       String   // 'americano' | 'super8'
  categorias      String[] // categorías objetivo (ej: ["6ta","7ma"])
  genero          String?  // 'masculino' | 'femenino' | 'mixto'
  fecha           String   // YYYY-MM-DD
  horaInicio      String   // HH:MM (franja de 1.5h)
  canchas         Int      @default(1)
  cupoMax         Int      // jugadores que entran
  visibilidad     String   @default("publica") // publica (se lista + notifica) | privada (solo por link)
  deadline        DateTime?
  politicaNoLlena String   @default("avisar") // cancelar | jugar_igual | avisar
  estado          String   @default("abierta") // abierta | confirmada | cancelada | jugada
  fixture         Json?    // fixture generado al confirmarse
  notas           String?
  createdBy       String?  // admin id
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  club     Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  cupos    ConvocatoriaCupo[]
  reservas Reserva[]

  @@map("convocatorias")
}

// Un anotado a una convocatoria. Jugador registrado (jugadorId) o nombre libre (link público).
model ConvocatoriaCupo {
  id             String   @id @default(cuid())
  convocatoriaId String
  jugadorId      String?  // null = anotado por nombre libre (sin cuenta)
  nombre         String?  // nombre si no es jugador registrado
  posicion       String?  // 'Drive' | 'Revés' | 'Ambas' (para armar parejas equilibradas)
  estado         String   @default("voy") // voy | espera | baja
  createdAt      DateTime @default(now())

  convocatoria Convocatoria @relation(fields: [convocatoriaId], references: [id], onDelete: Cascade)
  jugador      Jugador?     @relation(fields: [jugadorId], references: [id], onDelete: SetNull)

  @@map("convocatoria_cupos")
}

// "Busco un jugador" (caso 2 del matching): un jugador necesita un cuarto YA para un turno
// suyo. Se notifica a los de su categoría; el primero que dice "voy" la cubre. NO reserva
// cancha (el turno ya existe) — por eso es un modelo propio, no una convocatoria.
model SolicitudJugador {
  id            String   @id @default(cuid())
  clubId        String
  solicitanteId String   // jugador que busca
  busco         String   @default("jugador") // 'jugador' (faltan 1-3) | 'pareja' (rival, 2 fijo)
  cupos         Int      @default(1) // lugares a llenar: 'jugador' 1-3 (elegible), 'pareja' = 2 fijo
  visibilidad   String   @default("privada") // 'privada' (solo notif a la categoría) | 'publica' (link compartible + lobby)
  reservaId     String?  // turno al que pertenece (para contexto / pre-llenado)
  categoria     String?  // legacy (1 categoría). El match nuevo usa `categorias` (rango).
  categorias    String[] @default([]) // categorías objetivo (rango): a quiénes se notifica y quiénes lo ven
  fecha         String   // YYYY-MM-DD
  horaInicio    String   // HH:MM
  nota          String?  // ej: "Cancha 2, falta drive"
  estado        String   @default("abierta") // abierta | completa | cubierta(legacy) | cancelada
  cubiertoPorId String?  // legacy (1 cupo): jugador que la cubrió. El roster nuevo va en participantes.
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  club         Club                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  solicitante  Jugador                 @relation("SolicitudSolicitante", fields: [solicitanteId], references: [id], onDelete: Cascade)
  cubiertoPor  Jugador?                @relation("SolicitudCubierto", fields: [cubiertoPorId], references: [id], onDelete: SetNull)
  participantes SolicitudParticipante[]

  @@map("solicitudes_jugador")
}

// Roster de un partido abierto: los jugadores que dijeron "¡Voy!" y ocuparon un cupo.
// (El solicitante NO va acá — es el titular; los participantes son los que se sumaron.)
model SolicitudParticipante {
  id          String   @id @default(cuid())
  solicitudId String
  jugadorId   String
  estado      String   @default("aceptado") // 'pendiente' (espera OK del titular) | 'aceptado'
  createdAt   DateTime @default(now())

  solicitud SolicitudJugador @relation(fields: [solicitudId], references: [id], onDelete: Cascade)
  jugador   Jugador          @relation(fields: [jugadorId], references: [id], onDelete: Cascade)

  @@unique([solicitudId, jugadorId]) // un jugador no se anota dos veces al mismo partido
  @@map("solicitud_participantes")
}
